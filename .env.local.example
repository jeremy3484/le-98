# ---------------------------------------------------------------------------
# Supabase — copier ce fichier en `.env.local` et renseigner les valeurs
# (Project Settings > API dans le dashboard Supabase)
# ---------------------------------------------------------------------------

# URL publique du projet Supabase (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique "anon" (sûre côté client, protégée par les policies RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé "service_role" — SECRET, à n'utiliser QUE côté serveur.
# Ne JAMAIS exposer au client ni committer une vraie valeur. Bypass la RLS.
SUPABASE_SERVICE_ROLE_KEY=
